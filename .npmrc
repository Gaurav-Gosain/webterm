# @xterm/addon-canvas ships a stale "@xterm/xterm": "^5.0.0" peer range on its
# 0.8.0 betas, which conflicts with the 6.1.0 beta core the kitty overlay needs
# for its APC parser. The addons are built in lockstep from the same tree, so
# the declared range is metadata drift rather than a real incompatibility.
legacy-peer-deps=true
